// 泛型结构体测试
struct Box<T> {
    value: T,
}

// 泛型类测试
class Container<T> {
    value: T,
}

// 多参数泛型测试
struct Pair<T, U> {
    first: T,
    second: U,
}

fn main() {
    // 测试泛型结构体
    Box<int> box = Box<int> { value: 42 };
    println(box.value);
    
    // 测试泛型类
    Container<int> container = Container<int>::new(42);
    println(container.get());
    
    // 测试多参数泛型
    Pair<int, string> pair = Pair<int, string> { first: 42, second: "hello" };
    println(pair.first);
    println(pair.second);
}
