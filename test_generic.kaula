// 泛型函数测试
fn print<T>(value: T) {
    println(value);
}

// 泛型结构体测试
struct Box<T> {
    value: T,
}

// 泛型类测试
class Container<T> {
    value: T,
    
    fn get() -> T {
        return value;
    }
}

// 多参数泛型测试
struct Pair<T, U> {
    first: T,
    second: U,
}

fn main() {
    // 测试泛型函数
    print<int>(42);
    print<string>("hello");
    
    // 测试泛型结构体
    let box = Box<int> { value: 42 };
    println(box.value);
    
    // 测试泛型类
    let container = Container<int>::new(42);
    println(container.get());
    
    // 测试多参数泛型
    let pair = Pair<int, string> { first: 42, second: "hello" };
    println(pair.first);
    println(pair.second);
}
